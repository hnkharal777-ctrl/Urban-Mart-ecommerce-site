<%- include('partials/header') %>

<section class="error-section">
    <div class="container">
        <div class="error-content">
            <h1>404</h1>
            <h2>Page Not Found</h2>
            <p><%= message %></p>
            <a href="/" class="btn btn-primary">Go Home</a>
        </div>
    </div>
</section>

<style>
    .error-section {
        padding: 5rem 0;
        text-align: center;
        min-height: 60vh;
        display: flex;
        align-items: center;
    }
    
    .error-content h1 {
        font-size: 6rem;
        color: var(--primary-color);
        margin-bottom: 1rem;
    }
    
    .error-content h2 {
        font-size: 2rem;
        margin-bottom: 1rem;
    }
    
    .error-content p {
        color: var(--secondary-color);
        margin-bottom: 2rem;
    }
</style>

<%- include('partials/footer') %>